<aside
  class="sidebar"
  x-show="sidebarVisible"
  x-transition
  :aria-hidden="!sidebarVisible"
  role="navigation"
  aria-label="Package navigation"
>
  <div class="sidebar-header">
    <h2>Packages</h2>
    <div class="sidebar-actions">
      <button
        @click="expandAll()"
        class="icon-button"
        title="Expand all packages"
        aria-label="Expand all packages"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="7 13 12 18 17 13"></polyline>
          <polyline points="7 6 12 11 17 6"></polyline>
        </svg>
      </button>
      <button
        @click="collapseAll()"
        class="icon-button"
        title="Collapse all packages"
        aria-label="Collapse all packages"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="17 11 12 6 7 11"></polyline>
          <polyline points="17 18 12 13 7 18"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <div class="sidebar-content" x-data="packageTree">
    <template x-if="data && data.packageTree">
      <div x-data="treeNode(data.packageTree)">
        <div class="tree-node" :class="{ 'selected': isSelected }">
          <div class="node-header">
            <button x-show="hasChildren" @click="toggle()" class="expand-icon" :class="{ 'expanded': expanded }">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
            <span class="no-icon" x-show="!hasChildren"></span>

            <svg class="package-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>

            <button @click="$store.app.selectPackage(node.id)" class="node-label" :class="{ 'active': isSelected }">
              <span x-text="node.name"></span>
            </button>

            <span class="count-badge" x-show="node.classCount > 0" x-text="node.classCount"></span>
          </div>

          <div class="node-children" x-show="expanded && hasChildren">
            <!-- Sub-packages -->
            <template x-for="child in (node.children || [])" :key="child.id">
              <div x-data="treeNode(child)">
                <div class="tree-node" :class="{ 'selected': isSelected }">
                  <div class="node-header">
                    <button x-show="hasChildren" @click="toggle()" class="expand-icon" :class="{ 'expanded': expanded }">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                      </svg>
                    </button>
                    <span class="no-icon" x-show="!hasChildren"></span>

                    <svg class="package-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                    </svg>

                    <button @click="$store.app.selectPackage(node.id)" class="node-label" :class="{ 'active': isSelected }">
                      <span x-text="node.name"></span>
                    </button>

                    <span class="count-badge" x-show="node.classCount > 0" x-text="node.classCount"></span>
                  </div>

                  <div class="node-children" x-show="expanded && hasChildren">
                    <!-- Sub-packages at this level -->
                    <template x-for="child in (node.children || [])" :key="child.id">
                      <div x-data="treeNode(child)" class="tree-continues">
                        <!-- Alpine.js will recursively instantiate treeNode for each child -->
                        <div class="tree-node" :class="{ 'selected': isSelected }">
                          <div class="node-header">
                            <button x-show="hasChildren" @click="toggle()" class="expand-icon" :class="{ 'expanded': expanded }">
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="9 18 15 12 9 6"></polyline>
                              </svg>
                            </button>
                            <span class="no-icon" x-show="!hasChildren"></span>
                            <svg class="package-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                            </svg>
                            <button @click="$store.app.selectPackage(node.id)" class="node-label" :class="{ 'active': isSelected }">
                              <span x-text="node.name"></span>
                            </button>
                            <span class="count-badge" x-show="node.classCount > 0" x-text="node.classCount"></span>
                          </div>
                        </div>
                      </div>
                    </template>

                    <!-- Classes at this level -->
                    <template x-for="classId in (node.classes || [])" :key="classId">
                      <div class="tree-node class-node" :class="{ 'selected': currentClass === classId }">
                        <div class="node-header">
                          <span class="no-icon"></span>
                          <svg class="class-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="3" y1="9" x2="21" y2="9"></line>
                            <line x1="9" y1="21" x2="9" y2="9"></line>
                          </svg>
                          <button @click="$store.app.selectClass(classId)" class="node-label" :class="{ 'active': currentClass === classId }">
                            <span x-text="getClass(classId)?.name"></span>
                          </button>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </template>

            <!-- Classes at root level -->
            <template x-for="classId in (node.classes || [])" :key="classId">
              <div class="tree-node class-node" :class="{ 'selected': currentClass === classId }">
                <div class="node-header">
                  <span class="no-icon"></span>
                  <svg class="class-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="3" y1="9" x2="21" y2="9"></line>
                    <line x1="9" y1="21" x2="9" y2="9"></line>
                  </svg>
                  <button @click="$store.app.selectClass(classId)" class="node-label" :class="{ 'active': currentClass === classId }">
                    <span x-text="getClass(classId)?.name"></span>
                  </button>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>
    </template>

    <div x-show="!data" class="sidebar-loading">
      <p>Loading packages...</p>
    </div>
  </div>
</aside>